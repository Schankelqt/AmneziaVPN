APP_ENV=dev
APP_PORT=8090

# Future real provider selector: mock | wgeasy | ssh_awg
VPN_PROVIDER=mock

# Telegram bot shared secret for server-to-server calls
BOT_API_TOKEN=change_me

# Admin UI reboot (HTTP Basic): must match the login/password you use for the admin site.
# If nginx uses auth_basic, set the same values here and add:
#   proxy_set_header Authorization $http_authorization;
# in the location that proxies to this app.
ADMIN_AUTH_USER=
ADMIN_AUTH_PASSWORD=
