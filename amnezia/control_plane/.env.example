APP_ENV=dev
APP_PORT=8090

# Provider selector: mock | wgeasy
VPN_PROVIDER=mock

# wg-easy API settings (required if VPN_PROVIDER=wgeasy)
WG_EASY_BASE_URL=http://127.0.0.1:51821
WG_EASY_USERNAME=admin
WG_EASY_PASSWORD=change_me
WG_EASY_VERIFY_TLS=false
WG_EASY_TIMEOUT_SECONDS=10

# Telegram bot shared secret for server-to-server calls
BOT_API_TOKEN=change_me

# HTTP Basic for the whole admin UI and API (browser shows login dialog). /health stays open.
# Leave both empty only for local dev without auth.
# If nginx also uses auth_basic, use the same login/password and add:
#   proxy_set_header Authorization $http_authorization;
ADMIN_AUTH_USER=
ADMIN_AUTH_PASSWORD=
